# =============================================================================
# Aurora.ai — Frontend (Vercel) environment variables
#
# For a SPLIT deployment (Vercel frontend + Railway backend), set BOTH vars to
# point at the Railway server. For a COMBINED deployment (single server serving
# both API and static files), leave both EMPTY so the frontend uses same-origin.
# =============================================================================

# Required for split Vercel + Railway deployment.
# The Railway backend URL (protocol + host + port, NO trailing /api).
# Example: https://auroraserver-production.up.railway.app
VITE_API_URL=""

# Required for split Vercel + Railway deployment.
# The Railway WebSocket endpoint (wss:// + host + /ws).
# Example: wss://auroraserver-production.up.railway.app/ws
VITE_WS_URL=""
