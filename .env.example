# ----- Database -----
DATABASE_URL="postgresql://aurora:aurora@localhost:5432/aurora?schema=public"

# ----- Cache / Queues -----
REDIS_URL="redis://localhost:6379"

# ----- Auth -----
JWT_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# ----- AI / Speech (optional — app runs with mock fallback if empty) -----
OPENAI_API_KEY=""
DEEPGRAM_API_KEY=""

# ----- Payments (optional placeholder) -----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ----- Storage (optional — local adapter used if empty) -----
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""

# ----- URLs / Ports -----
WEB_URL="http://localhost:5173"
SERVER_URL="http://localhost:4000"
PORT=4000
