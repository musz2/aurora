STRIPE_WEBHOOK_SECRET=""

# ----- Storage (optional — local adapter used if empty) -----
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""

# ----- Integrations (optional — cards show "Not configured" until set) -----
