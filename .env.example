# =============================================================================
# Aurora.ai — environment configuration
#
# Aurora runs FULLY in mock/demo mode with only the [REQUIRED — mock mode] vars
# below. Everything marked [OPTIONAL — future] enables a real provider later; it
# is never required and the app fails honestly (no fake provider behavior) until
# you set it. Use safe placeholders only — never commit real secrets.
# =============================================================================

# ----- App -------------------------------------------------------------------
# development | production. Production enables stricter env validation + logging.
NODE_ENV="development"

# ----- Server [REQUIRED — mock mode] ----------------------------------------
# Port the API binds to (Railway/most hosts inject PORT automatically).
PORT=4000
# Public URL of this server (used in links/log output).
SERVER_URL="http://localhost:4000"

# ----- Web [REQUIRED — mock mode] -------------------------------------------
# Canonical web origin. In production set this to your Vercel URL.
FRONTEND_URL="http://localhost:5173"
# Legacy alias for FRONTEND_URL (kept for compatibility).
WEB_URL="http://localhost:5173"
# Optional extra CORS origins, comma-separated (e.g. preview deployments).
CORS_ALLOWED_ORIGINS=""
# Frontend build-time API endpoints. Leave empty for same-origin, or point at
# your deployed backend (Railway) for a split Vercel + Railway deployment.
# The code always appends /api to the URL, so omit it here.
VITE_API_URL="http://localhost:4000"
VITE_WS_URL="ws://localhost:4000/ws"

# ----- Database [REQUIRED — mock mode] --------------------------------------
DATABASE_URL="postgresql://aurora:aurora@localhost:5432/aurora?schema=public"

# ----- Redis [OPTIONAL — falls back to in-memory cache if empty] ------------
REDIS_URL="redis://localhost:6379"

# ----- Auth / JWT [REQUIRED — set strong values in production] --------------
JWT_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# ----- Mock / demo mode ------------------------------------------------------
# No flag needed: with the AI/Speech keys below empty, Aurora uses clearly
# labeled demo output for demo sessions/uploads and returns honest
# "not configured" errors for real ones. Seed demo data with: pnpm db:seed

# ----- Deepgram (speech-to-text) [OPTIONAL — future] ------------------------
DEEPGRAM_API_KEY=""
UPLOAD_TRANSCRIPTION_PROVIDER="deepgram"

# ----- OpenAI (summaries / chat / live copilot) [OPTIONAL — future] ---------
OPENAI_API_KEY=""

# ----- Google (Calendar / Meet / Drive) [OPTIONAL — future] -----------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/api/integrations/oauth/google/callback"
GOOGLE_DRIVE_FOLDER_ID=""

# ----- Microsoft (Teams / Outlook Calendar) [OPTIONAL — future] -------------
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_REDIRECT_URI="http://localhost:4000/api/integrations/oauth/microsoft/callback"
MICROSOFT_TENANT_ID="common"

# ----- Zoom [OPTIONAL — future] ---------------------------------------------
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""

# ----- Slack [OPTIONAL — future] --------------------------------------------
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_REDIRECT_URI="http://localhost:4000/api/integrations/oauth/slack/callback"
SLACK_BOT_TOKEN=""
SLACK_DEFAULT_CHANNEL_ID=""

# ----- HubSpot [OPTIONAL — future] ------------------------------------------
HUBSPOT_ACCESS_TOKEN=""
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""
HUBSPOT_REDIRECT_URI="http://localhost:4000/api/integrations/oauth/hubspot/callback"
HUBSPOT_PRIVATE_APP_TOKEN=""

# ----- Other CRM / Docs / Tasks [OPTIONAL — future] -------------------------
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""
DROPBOX_CLIENT_ID=""
DROPBOX_CLIENT_SECRET=""
NOTION_API_KEY=""
NOTION_DATABASE_ID=""
JIRA_BASE_URL=""
JIRA_EMAIL=""
JIRA_API_TOKEN=""
ASANA_ACCESS_TOKEN=""
ASANA_PROJECT_ID=""
ZAPIER_WEBHOOK_URL=""

# ----- Stripe (billing) [OPTIONAL — future] ---------------------------------
# With these empty, billing runs in clearly-labeled demo mode (no real charges).
# Set the secret key to enable real Checkout + Customer Portal, the webhook secret
# to apply plan changes after payment, and a Price ID per paid plan for checkout.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""

# ----- Storage (S3-compatible) [OPTIONAL — local disk used if empty] --------
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""

# ----- Email export (SMTP) [OPTIONAL — future] ------------------------------
SMTP_HOST=""
SMTP_USER=""
SMTP_PASS=""
